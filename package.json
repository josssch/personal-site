        "prettier-plugin-tailwindcss": "^0.7.2",
        "svelte": "5.53.6",
        "svelte-check": "^4.4.4",
        "tailwindcss": "^4.2.1",
        "typescript": "^5.9.3",
        "vite": "^7.3.1"
    },
